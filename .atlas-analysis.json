  "keyFeatures": [
    "1000+ pre-built toolkits for popular services (GitHub, Gmail, Slack, etc.)",
    "Multi-language SDK support (TypeScript and Python)",
    "Universal provider system supporting OpenAI, Anthropic, LangChain, CrewAI, and more",
    "Managed authentication and connected accounts",
    "Custom tool creation with type-safe schemas",
    "Tool execution with automatic file handling",
    "Real-time triggers and webhooks",
    "MCP (Model Context Protocol) server support via Rube",
    "CLI for code generation and authentication",
    "Tool versioning and toolkit management",
    "Cross-platform support (Node.js, Deno, Cloudflare Workers)",
    "Tool Router for agentic workflows"
  ],
  "publicApiSurface": [
    "Composio - Main SDK class",
    "composio.tools.get() - Fetch tools by toolkit",
    "composio.tools.execute() - Execute tool with parameters",
    "composio.tools.createCustomTool() - Create custom tools",
    "composio.toolkits.list() - List available toolkits",
    "composio.connectedAccounts.create() - Create connected account",
    "composio.connectedAccounts.get() - Get connected account",
    "composio.authConfigs.create() - Create auth configuration",
    "composio.triggers.subscribe() - Subscribe to triggers",
    "composio.mcp.createServer() - Create MCP server",
    "OpenAIProvider - OpenAI integration",
    "AnthropicProvider - Anthropic integration",
    "LangChainProvider - LangChain integration",
    "createConnectionRequest() - OAuth flow helper",
    "jsonSchemaToZodSchema() - Schema conversion utility",
    "@composio/cli - Command-line interface"
  ]
